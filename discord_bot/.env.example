# Copy to `.env` and fill in locally. Do not commit `.env`.
# discord.py does not load this file by default — export variables in your shell, or use a process manager.

# Required (Bot → Token in Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Optional
AVIATION_HUB_BASE_URL=http://127.0.0.1:4010
DISCORD_GUILD_ID=

# /info: add-bot link (full URL from Portal OAuth2 URL Generator), or auto-build from Application ID:
# AVBOT_ADD_BOT_URL=https://discord.com/oauth2/authorize?client_id=...&permissions=...&scope=bot%20applications.commands
# AVBOT_SUPPORT_SERVER_URL=https://discord.gg/your-invite

# Used to build default invite when AVBOT_ADD_BOT_URL is unset (same snowflake as “Application ID” / OAuth client_id):
# DISCORD_APPLICATION_ID=
# DISCORD_CLIENT_ID=   # optional alias; bot accepts either

# Not read by bot.py (gateway). Portal reference only:
# DISCORD_PUBLIC_KEY=
